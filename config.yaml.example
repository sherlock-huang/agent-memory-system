# Agent Memory System - Configuration
# MySQL Cloud Connection
#
# ⚠️ 敏感信息通过环境变量配置:
#   - MEMORY_DB_PASSWORD: 数据库密码 (必需)
#   - MEMORY_DB_HOST: 数据库主机 (默认: 218.201.18.131)
#   - MEMORY_DB_USER: 数据库用户名 (默认: root1)
#
# 生产环境请使用环境变量，运行前先设置:
#   Windows: $env:MEMORY_DB_PASSWORD = "密码"
#   Linux/macOS: export MEMORY_DB_PASSWORD="密码"

database:
  type: mysql
  host: "${MEMORY_DB_HOST:-218.201.18.131}"
  port: 8999
  database: "agent_memory"
  user: "${MEMORY_DB_USER:-root1}"
  password: "${MEMORY_DB_PASSWORD}"
  charset: "utf8mb4"
  
  pool:
    min_size: 5
    max_size: 20
    max_idle_time: 300
    pool_recycle: 3600
  
  timeout:
    connect: 10
    read: 30
    write: 30

source: "cli"
agent_id: null

search:
  default_limit: 10
  max_limit: 100

log_level: "INFO"
