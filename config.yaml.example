# Agent Memory System - Configuration
# ===============================
#
# 敏感信息通过环境变量配置:
#   - MEMORY_DB_PASSWORD: 数据库密码 (必需)
#   - MINIO_SECRET_KEY: MinIO 密码 (可选，有默认值)
#
# 设置环境变量示例:
#   Windows PowerShell: 
#     $env:MEMORY_DB_PASSWORD = "your_password"
#     [Environment]::SetEnvironmentVariable("MEMORY_DB_PASSWORD", "your_password", "User")
#   
#   Linux/macOS:
#     export MEMORY_DB_PASSWORD="your_password"
#     echo 'export MEMORY_DB_PASSWORD="your_password"' >> ~/.bashrc

# MinIO 云端存储
minio:
  endpoint: "http://YOUR_SERVER_IP:8010"
  access_key: "YOUR_ACCESS_KEY"
  secret_key: "YOUR_SECRET_KEY"
  bucket: "openclaw"
  region: "cn-east-1"
  cache_dir: "./cache/experiences"

# MySQL 数据库
database:
  type: mysql
  host: "YOUR_SERVER_IP"
  port: 8999
  database: "agent_memory"
  user: "root1"
  password: "${MEMORY_DB_PASSWORD}"
  charset: "utf8mb4"
  
  pool:
    min_size: 5
    max_size: 20
    max_idle_time: 300
    pool_recycle: 3600
  
  timeout:
    connect: 10
    read: 30
    write: 30

source: "cli"
agent_id: null

search:
  default_limit: 10
  max_limit: 100

log_level: "INFO"
